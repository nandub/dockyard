{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["caddy", "site", "upstream", "service"],
  "properties": {
    "caddy": {
      "type": "object",
      "required": ["image", "tag", "email"],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 1,
          "description": "Caddy image repository."
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Caddy image tag."
        },
        "email": {
          "type": "string",
          "minLength": 3,
          "description": "Email address used for ACME account registration."
        }
      },
      "additionalProperties": false
    },
    "site": {
      "type": "object",
      "required": ["hostname"],
      "properties": {
        "hostname": {
          "type": "string",
          "minLength": 1,
          "description": "Public hostname for automatic HTTPS."
        }
      },
      "additionalProperties": false
    },
    "upstream": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1,
          "description": "HTTP upstream URL Caddy should proxy to."
        }
      },
      "additionalProperties": false
    },
    "service": {
      "type": "object",
      "required": ["httpPort", "httpsPort"],
      "properties": {
        "httpPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Host HTTP port."
        },
        "httpsPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Host HTTPS port."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
